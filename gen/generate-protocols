#!/usr/bin/env python3
#
# SPDX-FileType: SOURCE
# SPDX-License-Identifier: Apache-2.0
#
# Earliest-wins merge of per-version protocols.py files into one
# version-agnostic protocols/_merged.py.
#
# Each SPDX version's bindings carry a self-contained protocols.py generated by
# shacl2code (--use-protocols yes).  This script walks versions oldest-first and
# for every class name records the first (earliest) version that defined it.
# The output re-exports each class from that earliest version, so downstream code
# can write:
#
#   from spdx_python_model import protocols
#   def f(e: protocols.Element) -> str: ...
#
# and accept objects from ANY 3.x version.

from __future__ import annotations

import argparse
import ast
import re
import sys
from pathlib import Path


_MACHINERY = {"SHACLObjectProtocol", "SHACLObjectSetProtocol"}

HEADER = """\
# SPDX-FileCopyrightText: 2026-present SPDX contributors
# SPDX-FileType: SOURCE
# SPDX-License-Identifier: Apache-2.0
#
# Generated by generate-protocols at build time. DO NOT EDIT.
\"\"\"Earliest-wins merge of per-version Protocol types.

Each class is re-exported from the earliest SPDX version that introduced it,
so the same protocol accepts objects from any later backward-compatible version.
\"\"\"

from __future__ import annotations
"""


def _modname(version: str) -> str:
    return "v" + re.sub(r"[^a-zA-Z0-9_]", "_", version)


def _domain_class_names(protocols_py: Path) -> list[str]:
    """Return names of domain Protocol classes from the generated protocols.py.

    Reads class definitions directly (no __all__ required) and skips the two
    static machinery classes that appear in every version.
    """
    tree = ast.parse(protocols_py.read_text())
    return [
        node.name
        for node in tree.body
        if isinstance(node, ast.ClassDef) and node.name not in _MACHINERY
    ]


def generate(versions: list[str], gen_dir: Path, out: Path) -> None:
    baseline = _modname(versions[0])

    earliest: dict[str, str] = {}
    for v in versions:
        mod = _modname(v)
        proto_file = gen_dir / mod / "protocols.py"
        if not proto_file.exists():
            sys.exit(
                f"generate-protocols: {proto_file} not found — "
                f"run generate-bindings first"
            )
        for name in _domain_class_names(proto_file):
            if name not in earliest:
                earliest[name] = mod

    if not earliest:
        sys.exit("generate-protocols: no protocol classes found in any version")

    by_version: dict[str, list[str]] = {}
    for name, mod in earliest.items():
        by_version.setdefault(mod, []).append(name)

    lines = [HEADER]
    lines.append(f"from ..bindings.{baseline}.protocols import (")
    lines.append("    SHACLObjectProtocol,")
    lines.append("    SHACLObjectSetProtocol,")
    lines.append(")")
    lines.append("")

    for v in versions:
        mod = _modname(v)
        names = sorted(by_version.get(mod, []))
        if not names:
            continue
        lines.append(f"from ..bindings.{mod}.protocols import (")
        for name in names:
            lines.append(f"    {name},")
        lines.append(")")
        lines.append("")

    all_names = ["SHACLObjectProtocol", "SHACLObjectSetProtocol"] + sorted(earliest)
    lines.append("__all__ = [")
    for name in all_names:
        lines.append(f'    "{name}",')
    lines.append("]")
    lines.append("")

    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text("\n".join(lines))


def main() -> int:
    parser = argparse.ArgumentParser(description="Merge per-version protocols")
    parser.add_argument("--versions", nargs="+", required=True)
    parser.add_argument("--gen-dir", type=Path, required=True)
    parser.add_argument("--out", type=Path, required=True)
    args = parser.parse_args()
    generate(args.versions, args.gen_dir, args.out)
    return 0


if __name__ == "__main__":
    sys.exit(main())
