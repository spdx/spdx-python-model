#! /bin/sh
#
# SPDX-FileType: SOURCE
# SPDX-License-Identifier: Apache-2.0
#
# Generate the per-version bindings and the bindings package __init__.py.

set -e

# SPDX versions to generate, space-separated.
# RELEASE: finalized versions.
# DRAFT: in-development versions (emit SPDXDraftWarning on use).
SPDX_VERSIONS_RELEASE="3.0.1"
SPDX_VERSIONS_DRAFT="3.1"
SPDX_VERSIONS="$SPDX_VERSIONS_RELEASE $SPDX_VERSIONS_DRAFT"

# Bundled model files shipped with this repo (one level up from gen/).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUNDLED_SPDX_DIR="${SCRIPT_DIR}/../spdx_model"

get_context_url() {
    echo "https://spdx.org/rdf/$1/spdx-context.jsonld"
}

# Per-version model source ("bundled", "custom", "network"),
# populated by the generation loop and read when writing the docstring.
VERSION_SOURCES=""

source_of() {
    printf '%s' "$VERSION_SOURCES" | while IFS='|' read -r ver src; do
        if [ "$ver" = "$1" ]; then
            printf '%s' "$src"
            break
        fi
    done
}

# Generate the per-version bindings with shacl2code.
# Each version ends up in its own subpackage (e.g. "v3_0_1").
for v in $SPDX_VERSIONS; do
    MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"

    CONTEXT_URL="$(get_context_url "$v")"

    # Resolve local model directory: explicit env var > bundled > network.
    # Set SHACL2CODE_SPDX_FORCE_NETWORK=1 to skip local files and fetch from network.
    # SOURCE records where the model came from, for the generated docstring.
    if [ -n "${SHACL2CODE_SPDX_FORCE_NETWORK}" ]; then
        LOCAL_DIR=""
        SOURCE="network (forced)"
    elif [ -n "${SHACL2CODE_SPDX_DIR}" ] && [ -d "${SHACL2CODE_SPDX_DIR}/$v" ]; then
        LOCAL_DIR="${SHACL2CODE_SPDX_DIR}/$v"
        SOURCE="custom"
    elif [ -d "${BUNDLED_SPDX_DIR}/$v" ]; then
        LOCAL_DIR="${BUNDLED_SPDX_DIR}/$v"
        SOURCE="bundled"
    else
        LOCAL_DIR=""
        SOURCE="network"
    fi

    # Record "version|source" for lookup when generating the docstring.
    VERSION_SOURCES="${VERSION_SOURCES}${v}|${SOURCE}
"

    if [ -n "$LOCAL_DIR" ]; then
        shacl2code generate \
            --input "file://${LOCAL_DIR}/spdx-model.ttl" \
            --input "file://${LOCAL_DIR}/spdx-json-serialize-annotations.ttl" \
            --context-url "file://${LOCAL_DIR}/spdx-context.jsonld" "$CONTEXT_URL" \
            --license Apache-2.0 \
            python \
            --output "$MODNAME"
    else
        shacl2code generate \
            --input "https://spdx.org/rdf/$v/spdx-model.ttl" \
            --input "https://spdx.org/rdf/$v/spdx-json-serialize-annotations.ttl" \
            --context "$CONTEXT_URL" \
            --license Apache-2.0 \
            python \
            --output "$MODNAME"
    fi
done

# Generate the bindings package __init__.py.
{
    echo '# SPDX-FileType: SOURCE'
    echo '# SPDX-License-Identifier: Apache-2.0'
    echo '#'
    echo '# Generated by generate-bindings at build time. DO NOT EDIT.'
    echo '"""SPDX model bindings, one submodule per version.'
    echo
    echo 'Available versions (model source in brackets):'
    for v in $SPDX_VERSIONS_RELEASE; do
        echo "  - $v [$(source_of "$v")]"
    done
    for v in $SPDX_VERSIONS_DRAFT; do
        echo "  - $v [$(source_of "$v")] (in development; may change without notice)"
    done
    echo '"""'
    echo
    echo '# JSON-LD @context URL -> version submodule name, for lazy lookup by load().'
    echo '_CONTEXT_TABLE = {'
    for v in $SPDX_VERSIONS; do
        MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"
        CONTEXT_URL="$(get_context_url "$v")"
        echo "    \"$CONTEXT_URL\": \"$MODNAME\","
    done
    echo '}'
    echo
    echo '# Submodule names for draft (in-development, not yet finalized) versions.'
    echo '_DRAFT_VERSIONS = frozenset({'
    for v in $SPDX_VERSIONS_DRAFT; do
        MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"
        echo "    \"$MODNAME\","
    done
    echo '})'
} > __init__.py

# Generate bindings/__init__.pyi: stub for the bindings package so that type
# checkers can resolve spdx_python_model.bindings.vX and spdx_python_model.vX
# types, while the runtime loads versions lazily
# (imported only under TYPE_CHECKING).
{
    echo '# SPDX-FileType: SOURCE'
    echo '# SPDX-License-Identifier: Apache-2.0'
    echo '#'
    echo '# Generated by generate-bindings at build time. DO NOT EDIT.'
    echo '"""Type stub for the bindings package.'
    echo
    echo 'Declares available version submodules so type checkers can resolve'
    echo '``spdx_python_model.bindings.vX`` imports.'
    echo 'Also imported by the top-level __init__.py under TYPE_CHECKING'
    echo 'to expose ``spdx_python_model.vX`` types.'
    echo '__all__ marks the names as re-exports for --no-implicit-reexport.'
    echo '"""'
    echo 'from typing import Dict'
    echo
    for v in $SPDX_VERSIONS; do
        MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"
        echo "from . import $MODNAME"
    done
    echo
    echo '_CONTEXT_TABLE: Dict[str, str]'
    echo
    echo '__all__ = ['
    for v in $SPDX_VERSIONS; do
        MODNAME="v$(echo "$v" | sed 's/[^a-zA-Z0-9_]/_/g')"
        echo "    \"$MODNAME\","
    done
    echo ']'
} > __init__.pyi
