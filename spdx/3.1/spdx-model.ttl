] [ sh:class ns5:ConjunctiveLicenseSet ] [ sh:class ns5:IndividualLicensingInfo ] [ sh:class ns7:Vulnerability ] [ sh:class ns7:VexAffectedVulnAssessmentRelationship ] [ sh:class ns7:CvssV3VulnAssessmentRelationship ] [ sh:class ns7:VexFixedVulnAssessmentRelationship ] [ sh:class ns7:SsvcVulnAssessmentRelationship ] [ sh:class ns7:CvssV4VulnAssessmentRelationship ] [ sh:class ns7:VexUnderInvestigationVulnAssessmentRelationship ] [ sh:class ns7:ExploitCatalogVulnAssessmentRelationship ] [ sh:class ns7:EpssVulnAssessmentRelationship ] [ sh:class ns7:CvssV2VulnAssessmentRelationship ] [ sh:class ns7:VexNotAffectedVulnAssessmentRelationship ] [ sh:class <https://spdx.org/rdf/3/terms/Extension/CdxPropertyEntry> ] [ sh:class ns2:Sbom ] [ sh:class ns2:Package ] [ sh:class ns2:ContentIdentifier ] [ sh:class ns2:Snippet ] [ sh:class ns2:File ] [ sh:class ns1:Organization ] [ sh:class ns1:Annotation ] [ sh:class ns1:DictionaryEntry ] [ sh:class ns1:MeasureOfLength ] [ sh:class ns1:PackageVerificationCode ] [ sh:class ns1:Person ] [ sh:class ns1:Requirement ] [ sh:class ns1:Relationship ] [ sh:class ns1:ExternalIdentifier ] [ sh:class ns1:ExternalRef ] [ sh:class ns1:PhysicalLocation ] [ sh:class ns1:UnitOfMeasure ] [ sh:class ns1:Specification ] [ sh:class ns1:NamespaceMap ] [ sh:class ns1:Tool ] [ sh:class ns1:SoftwareAgent ] [ sh:class ns1:MeasureOfMass ] [ sh:class ns1:DefinedType ] [ sh:class ns1:IndividualElement ] [ sh:class ns1:Agent ] [ sh:class ns1:ContactPointRelationship ] [ sh:class ns1:Bom ] [ sh:class ns1:ExternalMap ] [ sh:class ns1:SpdxDocument ] [ sh:class ns1:ElementMap ] [ sh:class ns1:Hash ] [ sh:class ns1:LifecycleScopedRelationship ] [ sh:class ns1:RoleRelationship ] [ sh:class ns1:Role ] [ sh:class ns1:Regulation ] [ sh:class ns1:SupportRelationship ] [ sh:class ns1:CreationInfo ] [ sh:class ns1:Bundle ] [ sh:class ns1:PositiveIntegerRange ] [ sh:class ns9:EvaluationResult ] [ sh:class ns9:RequirementVerification ] [ sh:class ns9:EvidenceRelationship ] 