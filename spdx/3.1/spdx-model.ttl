            sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" ],
        [ sh:class ns1:Location ;
            sh:nodeKind sh:IRI ;
            sh:path ns1:actionLocation ],
        [ sh:datatype xsd:dateTimeStamp ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path ns1:startTime ;
            sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" ] .

