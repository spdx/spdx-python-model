ns1:Action a owl:Class,
        sh:NodeShape ;
    rdfs:comment "Class that describes an action that has occurred."@en ;
    rdfs:subClassOf ns1:Artifact ;
    sh:nodeKind sh:IRI ;
    sh:property [ sh:message "https://spdx.org/rdf/3/terms/Core/Action is an abstract class and should not be instantiated directly. Instantiate a subclass instead."@en ;
